      "blocks": {
        "t1": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>La pettorina è arrivata in tre giorni e si vede subito la qualità. Luna la indossa volentieri, non si tira più al guinzaglio. Servizio cortese, consiglio davvero.</p>",
            "author": "Giulia M.",
            "role": "Milano",
            "rating": 5
