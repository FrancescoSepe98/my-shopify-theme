        "t2": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Avevo dei dubbi sul tiragraffi, invece il mio Romeo lo usa ogni giorno e ha smesso di rovinare il divano. Materiali solidi e prezzo onesto.</p>",
            "author": "Davide R.",
            "role": "Torino",
            "rating": 5
          }
        },
        "t3": {
          "type": "testimonial",
          "settings": {
            "quote": "<p>Cuccia ortopedica perfetta per la mia Bea, ormai anziana. Imbottitura morbida e tessuto facile da lavare. Sono tornata a comprare anche la ciotola.</p>",
            "author": "Sofia B.",
            "role": "Bologna",
            "rating": 5
          }
