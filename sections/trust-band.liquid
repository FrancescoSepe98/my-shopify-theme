{{ 'section-trust-band.css' | asset_url | stylesheet_tag }}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="trust-band page-width section-{{ section.id }}-padding isolate">
    {%- if section.settings.heading != blank -%}
      <h2 class="trust-band__heading {{ section.settings.heading_size }} inline-richtext">
        {{- section.settings.heading -}}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul
        class="trust-band__grid list-unstyled"
        role="list"
        style="--columns-desktop: {{ section.settings.columns_desktop }};"
      >
        {%- for block in section.blocks -%}
          <li class="trust-band__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != 'none' -%}
              <div class="trust-band__icon" aria-hidden="true">
                {%- render 'icon-accordion', icon: block.settings.icon -%}
              </div>
            {%- endif -%}
            <div class="trust-band__content">
              {%- if block.settings.heading != blank -%}
                <p class="trust-band__title">{{ block.settings.heading | escape }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="trust-band__text">{{ block.settings.text | escape }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust band",
  "tag": "section",
  "class": "section section-trust-band",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "",
      "label": "Heading",
      "info": "Leave empty for a clean strip layout"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns on desktop"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-2",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "padlock", "label": "Padlock" },
            { "value": "lock", "label": "Lock" },
            { "value": "chat_bubble", "label": "Chat" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "check_mark", "label": "Check mark" },
            { "value": "gift_card", "label": "Gift" },
            { "value": "box", "label": "Box" }
          ],
          "default": "truck",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Free EU shipping",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "text",
          "default": "On all orders over €60",
          "label": "Subtext"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Trust band",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "heading": "Free EU shipping",
            "text": "On all orders over €60"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "return",
            "heading": "30-day returns",
            "text": "Easy, no-questions exchanges"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "padlock",
            "heading": "Secure payment",
            "text": "SSL & 3D Secure checkout"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "chat_bubble",
            "heading": "Friendly support",
            "text": "Mon-Fri, real humans"
          }
        }
      ]
    }
  ]
}
{% endschema %}
