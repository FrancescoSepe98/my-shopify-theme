{% comment %}
  PET: Animal size/weight selector (informational).

  - Renders nothing if `product.metafields.custom.pet_size_options` is empty
    or missing — graceful fallback, no error.
  - Does NOT pilot the Shopify variant picker. The selected size is written
    as a line item property on the product form (properties[<name>]).
  - The hidden input is connected to the product form via the `form` attribute
    because blocks are siblings, not children, of the buy_buttons form.

  Metafield format expected (list.single_line_text):
    "Label|range"   e.g. "XS|0-3", "S|3-7", "M|7-15", "L|15-30", "XL|30+"
    The range unit follows the block's `weight_unit` setting.

  Accepts:
    - block            (required)
    - product          (required)
    - product_form_id  (required)  matches the {%- form 'product' -%} id
{% endcomment %}

{%- liquid
  assign size_options = product.metafields.custom.pet_size_options.value
-%}

{%- if size_options.size > 0 -%}
  {{ 'component-pet.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'pet-size-selector.js' | asset_url }}" defer="defer"></script>

  {%- assign mode = block.settings.mode | default: 'dropdown' -%}
  {%- assign unit = block.settings.weight_unit | default: 'kg' -%}
  {%- assign property_name = block.settings.property_name | default: 'Recommended size' -%}
  {%- assign label_text = block.settings.label -%}
  {%- if label_text == blank -%}
    {%- assign label_text = 'products.pet.size_selector.label' | t -%}
  {%- endif -%}

  <pet-size-selector
    class="pet-size-selector"
    data-mode="{{ mode }}"
    data-unit="{{ unit }}"
    data-recommended-tmpl="{{ 'products.pet.size_selector.recommended' | t | escape }}"
    data-out-of-range-text="{{ 'products.pet.size_selector.out_of_range' | t | escape }}"
    {{ block.shopify_attributes }}
  >
    <div class="pet-size-selector__header">
      <label class="pet-size-selector__label form__label" for="PetSize-{{ block.id }}">
        {{- label_text -}}
      </label>
      {%- if block.settings.show_size_guide -%}
        <modal-opener
          class="pet-size-selector__guide-opener"
          data-modal="#PetSizeGuideModal-{{ block.id }}"
        >
          <button
            type="button"
            class="pet-size-selector__guide-link"
            aria-haspopup="dialog"
          >
            {{- 'products.pet.size_selector.size_guide_link' | t -}}
          </button>
        </modal-opener>
      {%- endif -%}
    </div>

    {%- if mode == 'weight_range' -%}
      <div class="pet-size-selector__row">
        <input
          type="number"
          inputmode="decimal"
          step="0.1"
          min="0"
          id="PetSize-{{ block.id }}"
          class="pet-size-selector__weight"
          placeholder="{{ 'products.pet.size_selector.weight_placeholder' | t }}"
          aria-describedby="PetSizeResult-{{ block.id }}"
          data-pet-weight-input
        >
        <span class="pet-size-selector__unit" aria-hidden="true">{{ unit }}</span>
      </div>
      <p
        id="PetSizeResult-{{ block.id }}"
        class="pet-size-selector__result"
        role="status"
        aria-live="polite"
      ></p>
      {%- comment -%} PET: parsed by pet-size-selector.js {%- endcomment -%}
      <script type="application/json" data-pet-ranges>
        [
          {%- for option in size_options -%}
            {%- assign parts = option | split: '|' -%}
            {%- assign size_label = parts[0] | strip -%}
            {%- assign size_range = parts[1] | default: '' | strip -%}
            { "label": {{ size_label | json }}, "range": {{ size_range | json }} }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      </script>
    {%- else -%}
      <select
        id="PetSize-{{ block.id }}"
        class="pet-size-selector__select"
        data-pet-size-select
      >
        <option value="">{{ 'products.pet.size_selector.choose' | t }}</option>
        {%- for option in size_options -%}
          {%- assign parts = option | split: '|' -%}
          {%- assign size_label = parts[0] | strip -%}
          {%- assign size_hint = parts[1] | default: '' | strip -%}
          {%- if size_hint != blank -%}
            {%- capture option_display -%}{{ size_label }} — {{ size_hint }} {{ unit }}{%- endcapture -%}
            {%- capture option_value -%}{{ size_label }} ({{ size_hint }} {{ unit }}){%- endcapture -%}
          {%- else -%}
            {%- assign option_display = size_label -%}
            {%- assign option_value = size_label -%}
          {%- endif -%}
          <option value="{{ option_value | escape }}">{{ option_display }}</option>
        {%- endfor -%}
      </select>
    {%- endif -%}

    {%- comment -%}
      PET: hidden line item property. `form` attr connects it to the product
      form even though this block is a sibling of buy_buttons. Disabled until
      a value is chosen — keeps unfilled orders clean.
    {%- endcomment -%}
    <input
      type="hidden"
      name="properties[{{ property_name | escape }}]"
      data-pet-recommended-size
      form="{{ product_form_id }}"
      value=""
      disabled
    >
  </pet-size-selector>

  {%- if block.settings.show_size_guide -%}
    {%- render 'pet-size-guide-modal', block: block, product: product -%}
  {%- endif -%}
{%- endif -%}
